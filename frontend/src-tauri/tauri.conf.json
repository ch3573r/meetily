{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "ClawScribe",
    "version": "0.5.13",
    "identifier": "net.rismondo.openclaw.clawscribe",
    "build": {
        "frontendDist": "../out",
        "devUrl": "http://localhost:3118",
        "beforeDevCommand": "pnpm dev",
        "beforeBuildCommand": "pnpm build"
    },
    "app": {
        "windows": [
            {
                "title": "ClawScribe",
                "width": 1100,
                "height": 700,
                "minWidth": 1100,
                "minHeight": 700,
                "resizable": true,
                "fullscreen": false,
                "decorations": false
            }
        ],
        "macOSPrivateApi": true,
        "security": {
            "csp": {
                "default-src": "'self'",
                "style-src": "'self' 'unsafe-inline'",
                "img-src": "'self' asset: https://asset.localhost data:",
                "connect-src": "'self' http://localhost:11434 http://localhost:5167 http://localhost:8178 https://api.ollama.ai"
            },
            "assetProtocol": {
                "enable": true,
                "scope": [
                    "$APPDATA/**"
                ]
            },
            "capabilities": [
                {
                    "identifier": "main",
                    "description": "Main window capability for ClawScribe app commands and UI services",
                    "windows": [
                        "main"
                    ],
                    "permissions": [
                        "core:path:default",
                        "core:event:default",
                        "core:window:default",
                        "core:app:default",
                        "core:resources:default",
                        "core:menu:default",
                        "core:tray:default",
                        "core:window:allow-close",
                        "core:window:allow-minimize",
                        "core:window:allow-start-dragging",
                        "core:window:allow-set-title",
                        "core:window:allow-toggle-maximize",
                        "store:default",
                        "notification:default",
                        "notification:allow-is-permission-granted",
                        "updater:default",
                        "process:default"
                    ]
                }
            ]
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "msi",
            "nsis"
        ],
        "createUpdaterArtifacts": true,
        "publisher": "OpenClaw",
        "copyright": "Copyright (c) OpenClaw contributors",
        "category": "Productivity",
        "shortDescription": "Windows meeting recorder with OpenClaw handoff.",
        "longDescription": "ClawScribe records meetings from the Windows user session, produces local transcripts and summaries, and can hand completed meeting artifacts to OpenClaw.",
        "icon": [
            "icons/icon.png",
            "icons/app_icon.icns",
            "icons/app_icon.ico"
        ],
        "resources": {
            "templates/": "templates/",
            "binaries/codex-app-server-runtime.json": "binaries/codex-app-server-runtime.json",
            "binaries/codex-app-server-runtime/": "binaries/codex-app-server-runtime/",
            "binaries/sherpa-onnx/*.dll": ""
        },
        "externalBin": [
            "binaries/llama-helper",
            "binaries/codex-app-server",
            "binaries/ffmpeg"
        ],
        "macOS": {
            "entitlements": "entitlements.plist",
            "signingIdentity": "-",
            "hardenedRuntime": true
        },
        "windows": {
            "allowDowngrades": false,
            "signCommand": "powershell -ExecutionPolicy Bypass -File scripts/sign-windows.ps1 -FilePath %1",
            "wix": {
                "upgradeCode": "8b6aff03-4baa-5d80-9239-e65d85c288d3"
            },
            "nsis": {
                "installerIcon": "icons/app_icon.ico",
                "uninstallerIcon": "icons/app_icon.ico",
                "installMode": "currentUser",
                "languages": [
                    "English"
                ],
                "startMenuFolder": "ClawScribe"
            }
        }
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ1OTgxNjI5NkZCOEI1NEIKUldSTHRiaHZLUmFZUlFEU0RQTFl3ZjdTT2RGV25EZGM1VHZYOGE0MWxpdndMNWtwbWN5S2hlMHUK",
            "endpoints": [
                "https://github.com/ch3573r/ClawScribe/releases/latest/download/latest.json"
            ]
        }
    }
}
